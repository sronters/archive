# Runtime
ENVIRONMENT=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://medarchive:medarchive@postgres:5432/medarchive
ALEMBIC_DATABASE_URL=postgresql+psycopg://medarchive:medarchive@postgres:5432/medarchive

# Queue
CELERY_BROKER_URL=amqp://medarchive:medarchive@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Cache
REDIS_URL=redis://redis:6379/1

# Object storage
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=medarchive
S3_SECRET_ACCESS_KEY=medarchive-password
S3_BUCKET=medarchive-originals
S3_REGION=us-east-1

# Auth
AUTH_MODE=local_jwt
JWT_SECRET=change-me-in-real-environments
LOCAL_API_KEYS=dev-admin:administrator,catalog_manager,senior_operator,operator,auditor,viewer,integration_client;dev-operator:operator,viewer;dev-integration:integration_client

# Remote catalog sync
REMOTE_SERVICE_CATALOG_URL=https://company.example/api/services
REMOTE_PARTNER_CATALOG_URL=https://company.example/api/partners
REMOTE_CATALOG_BEARER_TOKEN=

# Webhooks
WEBHOOK_SIGNING_SECRET=change-me-per-endpoint

# Malware scanning
MALWARE_SCANNER_MODE=not_configured

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
